generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id          String   @id @default(uuid())
  plateNumber String
  carModel    String
  driverName  String
  createdAt   DateTime @default(now())

  trips       Trip[]
}

model Trip {
  id        String   @id @default(uuid())
  vehicleId String
  startTime DateTime
  endTime   DateTime?
  status    String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}